{
  "$schema": "https://biomejs.dev/schemas/2.4.10/schema.json",
  "files": {
    "includes": ["ts/**/*.ts", "*.js", "*.json", "*.md"]
  },
  "formatter": {
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 80
  },
  "javascript": {
    "formatter": {
      "semicolons": "always"
    },
    "globals": ["__pvwasmSceneData", "__pvwasmContainer", "vtkReady", "vtkWASM"]
  },
  "linter": {
    "enabled": true,
    "rules": {
      "a11y": "error",
      "complexity": "error",
      "correctness": "error",
      "nursery": "error",
      "performance": "error",
      "security": "error",
      "style": "error",
      "suspicious": "error"
    }
  },
  "overrides": [
    {
      "includes": ["**"],
      "linter": {
        "rules": {
          "complexity": {
            "noExcessiveLinesPerFunction": "off",
            "useMaxParams": "off"
          },
          "nursery": {
            "noIncrementDecrement": "off",
            "noTernary": "off"
          },
          "performance": {
            "noAwaitInLoops": "off"
          },
          "style": {
            "noMagicNumbers": "off",
            "noNestedTernary": "off",
            "useConsistentArrayType": "off"
          },
          "suspicious": {
            "noConsole": "off"
          }
        }
      }
    }
  ]
}
