{
  "$schema": "https://biomejs.dev/schemas/2.4.10/schema.json",
  "files": {
    "includes": ["ts/**/*.ts", "ts/**/*.tsx", "*.js", "*.json", "*.md"]
  },
  "formatter": {
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 80
  },
  "javascript": {
    "formatter": {
      "semicolons": "always"
    },
    "globals": [],
    "jsxRuntime": "reactClassic"
  },
  "linter": {
    "enabled": true,
    "rules": {
      "a11y": "error",
      "complexity": "error",
      "correctness": "error",
      "nursery": "error",
      "performance": "error",
      "security": "error",
      "style": "error",
      "suspicious": "error"
    }
  },
  "overrides": [
    {
      "includes": ["ts/renderer.ts"],
      "linter": {
        "rules": {
          "complexity": {
            "noExcessiveCognitiveComplexity": "off",
            "noExcessiveLinesPerFunction": "off",
            "noVoid": "off"
          },
          "correctness": {
            "noUndeclaredVariables": "off"
          },
          "nursery": {
            "noExcessiveLinesPerFile": "off",
            "noIncrementDecrement": "off",
            "noTernary": "off"
          },
          "performance": {
            "noAwaitInLoops": "off"
          },
          "security": {
            "noSecrets": "off"
          },
          "style": {
            "noNestedTernary": "off"
          }
        }
      }
    },
    {
      "includes": ["ts/src/**/*.tsx"],
      "linter": {
        "rules": {
          "complexity": {
            "noExcessiveCognitiveComplexity": "off",
            "noExcessiveLinesPerFunction": "off",
            "noVoid": "off"
          },
          "nursery": {
            "noInlineStyles": "off",
            "noTernary": "off"
          },
          "style": {
            "noNestedTernary": "off",
            "noJsxLiterals": "off",
            "useExportsLast": "off"
          },
          "suspicious": {
            "noExplicitAny": "off",
            "noReactSpecificProps": "off"
          }
        }
      }
    },
    {
      "includes": ["ts/vtk.d.ts"],
      "linter": {
        "rules": {
          "nursery": {
            "noExcessiveLinesPerFile": "off",
            "useConsistentMethodSignatures": "off"
          },
          "style": {
            "useNamingConvention": "off",
            "useConsistentTypeDefinitions": "off"
          }
        }
      }
    }
  ]
}
