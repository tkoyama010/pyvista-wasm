{
  "private": true,
  "type": "module",
  "scripts": {
    "build": "esbuild ts/renderer.ts --bundle --format=iife --outfile=src/pyvista_wasm/templates/renderer.js --target=es2017",
    "lint": "biome check",
    "format": "biome format --write",
    "typecheck": "tsc --noEmit -p ts/tsconfig.json",
    "watch": "esbuild ts/renderer.ts --bundle --format=iife --outfile=src/pyvista_wasm/templates/renderer.js --target=es2017 --watch"
  },
  "xo": {
    "prettier": true,
    "semicolon": true,
    "space": 2,
    "rules": {
      "no-inline-comments": "error"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "esbuild": "^0.27",
    "eslint-plugin-jsdoc": "^62.8.1",
    "typescript": "^6.0",
    "xo": "^2.0.2"
  }
}
